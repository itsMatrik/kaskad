---
import categoriesData from '../data/categories.json';

interface CategoryInfo {
  slug: string;
  children: string[];
}

const categories = categoriesData as Record<string, CategoryInfo>;

export interface Props {
  categoryCounts: Record<string, number>;
  subcategoryCounts: Record<string, number>;
}

const { categoryCounts, subcategoryCounts } = Astro.props;
---

<aside class="w-full lg:w-72 shrink-0" id="category-sidebar">
  <!-- Mobile Category Toggle -->
  <button
    id="category-toggle-mobile"
    class="lg:hidden w-full flex items-center justify-between px-4 py-3 bg-primary-700 text-white rounded-xl mb-3 text-sm font-semibold hover:bg-primary-600 transition-colors duration-200"
  >
    <span class="flex items-center gap-2">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 10h16M4 14h16M4 18h16" /></svg>
      Категории
    </span>
    <svg class="w-4 h-4 transition-transform duration-200" id="category-chevron" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
  </button>

  <!-- Category Panel -->
  <div id="category-panel" class="hidden lg:block bg-white border border-surface-200 rounded-2xl overflow-hidden shadow-sm mb-4">
    <div class="p-4 border-b border-surface-100 flex items-center justify-between bg-primary-50/50">
      <h2 class="font-bold text-primary-800 text-sm flex items-center gap-2">
        <svg class="w-4 h-4 text-primary-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 10h16M4 14h16M4 18h16" /></svg>
        Категории
      </h2>
      <button
        id="clear-category"
        class="text-xs text-primary-600 hover:text-primary-800 font-semibold transition-colors duration-200"
      >
        Сбросить
      </button>
    </div>

    <div class="divide-y divide-surface-100 max-h-[600px] overflow-y-auto">
      {Object.entries(categories).map(([catName, catData]) => {
        const count = categoryCounts[catName] || 0;
        const hasChildren = catData.children && catData.children.length > 0;
        return (
          <div class="category-group" data-category-name={catName}>
            <button
              class="category-toggle w-full flex items-center justify-between px-4 py-3 text-left hover:bg-primary-50/50 transition-colors duration-150"
              data-category={catName}
              aria-expanded="false"
            >
              <span class="flex items-center gap-2">
                <svg class="w-4 h-4 text-primary-400 shrink-0 category-folder-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z" /></svg>
                <span class="text-sm font-semibold text-surface-700 category-label">{catName}</span>
              </span>
              <span class="flex items-center gap-2">
                <span class="text-xs text-surface-400 font-medium">{count}</span>
                {hasChildren && (
                  <svg class="w-3.5 h-3.5 text-primary-400 transition-transform duration-200 category-chevron-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                  </svg>
                )}
              </span>
            </button>
            {hasChildren && (
              <div class="category-children hidden" data-parent-category={catName}>
                <div class="pb-2 pl-6 pr-4 space-y-0.5">
                  <button
                    class="subcategory-link w-full flex items-center justify-between px-3 py-2 text-left text-sm text-surface-600 hover:text-primary-700 hover:bg-primary-50/50 rounded-lg transition-colors duration-150"
                    data-category={catName}
                    data-subcategory=""
                  >
                    <span>Все {catName.toLowerCase()}</span>
                    <span class="text-xs text-surface-400">{count}</span>
                  </button>
                  {catData.children.map((subName) => {
                    const subCount = subcategoryCounts[subName] || 0;
                    return (
                      <button
                        class="subcategory-link w-full flex items-center justify-between px-3 py-2 text-left text-sm text-surface-600 hover:text-primary-700 hover:bg-primary-50/50 rounded-lg transition-colors duration-150"
                        data-category={catName}
                        data-subcategory={subName}
                      >
                        <span>{subName}</span>
                        <span class="text-xs text-surface-400">{subCount}</span>
                      </button>
                    );
                  })}
                </div>
              </div>
            )}
          </div>
        );
      })}
    </div>
  </div>
</aside>
