---
export interface FilterOption {
  label: string;
  value: string;
}

export interface FilterGroup {
  id: string;
  label: string;
  options: FilterOption[];
}

export interface Props {
  filters: FilterGroup[];
  activeFilters: Record<string, string[]>;
}

const { filters, activeFilters } = Astro.props;
---

<aside class="w-full lg:w-72 shrink-0" id="filter-sidebar">
  <!-- Mobile Filter Toggle -->
  <button
    id="filter-toggle-mobile"
    class="lg:hidden w-full flex items-center justify-between px-4 py-3 bg-primary-700 text-white rounded-xl mb-3 text-sm font-semibold hover:bg-primary-600 transition-colors duration-200"
  >
    <span class="flex items-center gap-2">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2.586a1 1 0 01-.293.707l-6.414 6.414a1 1 0 00-.293.707V17l-4 4v-6.586a1 1 0 00-.293-.707L3.293 7.293A1 1 0 013 6.586V4z" /></svg>
      Фильтры
    </span>
    <svg class="w-4 h-4 transition-transform duration-200" id="filter-chevron" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
  </button>

  <!-- Filter Panel -->
  <div id="filter-panel" class="hidden lg:block bg-white border border-surface-200 rounded-2xl overflow-hidden shadow-sm">
    <div class="p-4 border-b border-surface-100 flex items-center justify-between bg-primary-50/50">
      <h2 class="font-bold text-primary-800 text-sm flex items-center gap-2">
        <svg class="w-4 h-4 text-primary-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2.586a1 1 0 01-.293.707l-6.414 6.414a1 1 0 00-.293.707V17l-4 4v-6.586a1 1 0 00-.293-.707L3.293 7.293A1 1 0 013 6.586V4z" /></svg>
        Фильтры
      </h2>
      <button
        id="clear-filters"
        class="text-xs text-primary-600 hover:text-primary-800 font-semibold transition-colors duration-200"
      >
        Сбросить
      </button>
    </div>

    <div class="divide-y divide-surface-100">
      {filters.map((group) => (
        <div class="filter-group" data-filter-id={group.id}>
          <button
            class="filter-toggle w-full flex items-center justify-between px-4 py-3.5 text-left hover:bg-primary-50/50 transition-colors duration-150"
            data-target={`filter-${group.id}`}
            aria-expanded="true"
          >
            <span class="text-sm font-semibold text-surface-700">{group.label}</span>
            <svg class="w-4 h-4 text-primary-400 transition-transform duration-200 filter-chevron-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </button>
          <div class="filter-dropdown open" id={`filter-${group.id}`}>
            <div class="px-4 pb-3.5 space-y-2 max-h-48 overflow-y-auto">
              {group.options.map((option) => (
                <label class="flex items-center gap-2.5 cursor-pointer group/cb p-1 rounded-md hover:bg-primary-50/50 transition-colors duration-150">
                  <input
                    type="checkbox"
                    name={group.id}
                    value={option.value}
                    class="w-4 h-4 rounded border-surface-300 text-primary-600 focus:ring-primary-500 focus:ring-offset-0 cursor-pointer transition-colors duration-150 filter-checkbox"
                    checked={activeFilters[group.id]?.includes(option.value)}
                  />
                  <span class="text-sm text-surface-600 group-hover/cb:text-primary-700 transition-colors duration-150 select-none">
                    {option.label}
                  </span>
                </label>
              ))}
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- Active Filters Tags -->
    <div id="active-filters-tags" class="px-4 py-3 border-t border-surface-100 hidden">
      <div class="text-xs font-semibold text-primary-600 mb-2">Выбрано:</div>
      <div id="active-filters-list" class="flex flex-wrap gap-1.5"></div>
    </div>
  </div>
</aside>
