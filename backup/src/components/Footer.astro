---
const phone = '+375(29) 760-46-93';
const email = 'golodok_07@mail.ru';
const currentYear = new Date().getFullYear();

const footerLinks = {
  catalog: [
    { label: 'Ткань ПВХ', href: '/#catalog' },
    { label: 'Оксфорд', href: '/#catalog' },
    { label: 'Ткань ПУ', href: '/#catalog' },
    { label: 'Нейлон', href: '/#catalog' },
    { label: 'Фурнитура', href: '/#catalog' },
  ],
  company: [
    { label: 'О компании', href: '/#about' },
    { label: 'Доставка и оплата', href: '/#delivery' },
    { label: 'Контакты', href: '/#contacts' },
  ],
};
---

<footer class="bg-primary-900 text-surface-300">
  <!-- Main Footer -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-14 lg:py-16">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-10 lg:gap-8">
      <!-- Brand Column -->
      <div class="sm:col-span-2 lg:col-span-1">
        <a href="/" class="inline-flex items-center justify-center bg-white px-3 py-2 rounded-xl mb-5 shadow-sm">
          <img src="/logo.png" alt="КаскадТекс" class="h-9 w-auto object-contain" />
        </a>
        <p class="text-sm leading-relaxed text-primary-300 mb-5 max-w-xs">
          Оптовая продажа тканей ПВХ и ПУ, оксфорд, таффета, фурнитура и сопутствующие материалы с доставкой по всей Республике Беларусь.
        </p>
        <div class="space-y-2">
          <a href={`tel:${phone.replace(/[^+\d]/g, '')}`} class="flex items-center gap-2 text-sm text-primary-200 hover:text-accent-400 transition-colors duration-200">
            <svg class="w-4 h-4 text-primary-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
            {phone}
          </a>
          <a href={`mailto:${email}`} class="flex items-center gap-2 text-sm text-primary-200 hover:text-accent-400 transition-colors duration-200">
            <svg class="w-4 h-4 text-primary-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
            {email}
          </a>
        </div>
      </div>

      <!-- Catalog Links -->
      <div>
        <h3 class="text-white font-bold text-sm uppercase tracking-wider mb-5 flex items-center gap-2">
          <div class="w-1 h-4 bg-accent-500 rounded-full"></div>
          Каталог
        </h3>
        <ul class="space-y-3">
          {footerLinks.catalog.map((link) => (
            <li>
              <a href={link.href} class="text-sm text-primary-300 hover:text-white hover:pl-1 transition-all duration-200 inline-block">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Company Links -->
      <div>
        <h3 class="text-white font-bold text-sm uppercase tracking-wider mb-5 flex items-center gap-2">
          <div class="w-1 h-4 bg-accent-500 rounded-full"></div>
          Компания
        </h3>
        <ul class="space-y-3">
          {footerLinks.company.map((link) => (
            <li>
              <a href={link.href} class="text-sm text-primary-300 hover:text-white hover:pl-1 transition-all duration-200 inline-block">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Schedule + CTA -->
      <div>
        <h3 class="text-white font-bold text-sm uppercase tracking-wider mb-5 flex items-center gap-2">
          <div class="w-1 h-4 bg-accent-500 rounded-full"></div>
          Режим работы
        </h3>
        <div class="text-sm space-y-2 mb-5">
          <div class="flex items-center gap-2">
            <div class="w-1.5 h-1.5 bg-green-400 rounded-full"></div>
            <span class="text-primary-200">Пн — Пт: 9:00 — 18:00</span>
          </div>
          <div class="flex items-center gap-2">
            <div class="w-1.5 h-1.5 bg-accent-400 rounded-full"></div>
            <span class="text-primary-200">Сб: 9:00 — 14:00</span>
          </div>
          <div class="flex items-center gap-2">
            <div class="w-1.5 h-1.5 bg-surface-500 rounded-full"></div>
            <span class="text-primary-400">Вс: выходной</span>
          </div>
        </div>
        <a
          href={`mailto:${email}`}
          class="inline-flex items-center gap-2 px-4 py-2.5 bg-accent-500 hover:bg-accent-600 text-white text-sm font-semibold rounded-xl transition-all duration-200 shadow-sm hover:shadow-md"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
          Написать нам
        </a>
      </div>
    </div>
  </div>

  <!-- Bottom Bar -->
  <div class="border-t border-white/10">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-5 flex flex-col sm:flex-row justify-between items-center gap-3">
      <p class="text-xs text-primary-400">&copy; {currentYear} КаскадТекс. Все права защищены.</p>
      <p class="text-xs text-primary-500">Оптовая продажа тканей в Беларуси</p>
    </div>
  </div>
</footer>
