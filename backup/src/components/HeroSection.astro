---
---

<section class="relative gradient-green text-white overflow-hidden">
  <!-- Subtle fabric pattern -->
  <div class="absolute inset-0 opacity-[0.05]" style="background-image: linear-gradient(45deg, rgba(255,255,255,0.1) 25%, transparent 25%), linear-gradient(-45deg, rgba(255,255,255,0.1) 25%, transparent 25%), linear-gradient(45deg, transparent 75%, rgba(255,255,255,0.1) 75%), linear-gradient(-45deg, transparent 75%, rgba(255,255,255,0.1) 75%); background-size: 28px 28px; background-position: 0 0, 0 14px, 14px -14px, -14px 0;"></div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-14 lg:py-20">
    <div class="max-w-2xl">
      <div class="inline-flex items-center gap-2 px-3 py-1.5 bg-white/10 backdrop-blur-sm border border-white/15 rounded-full text-accent-300 text-xs font-semibold tracking-wide uppercase mb-5">
        <span class="w-1.5 h-1.5 bg-accent-400 rounded-full"></span>
        Оптовая продажа тканей с 2009 года
      </div>
      <h1 class="text-3xl sm:text-4xl lg:text-5xl font-bold tracking-tight leading-[1.1] mb-5">
        Ткани оптом
        <span class="block mt-1 text-accent-300">для вашего производства</span>
      </h1>
      <p class="text-primary-200 text-base lg:text-lg leading-relaxed mb-7">
        Ткани ПВХ и ПУ, оксфорд, таффета, фурнитура и сопутствующие материалы.
        Конкурентные цены, сертификаты ГОСТ и доставка по всей Беларуси.
      </p>

      <div class="flex flex-wrap gap-3 mb-8">
        <a
          href="#catalog"
          class="btn-accent inline-flex items-center gap-2 px-7 py-3.5 bg-accent-500 hover:bg-accent-600 text-white font-semibold rounded-xl text-sm"
        >
          Смотреть каталог
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
        </a>
        <a
          href="#contacts"
          class="inline-flex items-center gap-2 px-6 py-3.5 border border-white/20 text-white font-medium rounded-xl hover:bg-white/10 transition-colors duration-200 text-sm backdrop-blur-sm"
        >
          Запросить прайс
        </a>
      </div>
    </div>

    <!-- Stats Bar -->
    <div class="mt-8 pt-8 border-t border-white/15 grid grid-cols-2 sm:grid-cols-4 gap-6 lg:gap-8">
      <div>
        <div class="text-2xl lg:text-3xl font-bold text-white">500+</div>
        <div class="text-sm text-primary-300 mt-0.5">Наименований</div>
      </div>
      <div>
        <div class="text-2xl lg:text-3xl font-bold text-white">15+</div>
        <div class="text-sm text-primary-300 mt-0.5">Лет на рынке</div>
      </div>
      <div>
        <div class="text-2xl lg:text-3xl font-bold text-white">200+</div>
        <div class="text-sm text-primary-300 mt-0.5">Клиентов</div>
      </div>
      <div>
        <div class="text-2xl lg:text-3xl font-bold text-white">24ч</div>
        <div class="text-sm text-primary-300 mt-0.5">Обработка заказа</div>
      </div>
    </div>
  </div>
</section>
