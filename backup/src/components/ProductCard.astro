---
export interface Props {
  id: number;
  slug: string;
  name: string;
  category: string;
  subcategory: string;
  image: string;
  imageHover: string;
  inStock: boolean;
  price: string;
  index?: number;
}

const { id, slug, name, category, subcategory, image, imageHover, inStock, price, index = 0 } = Astro.props;
---

<article
  class="product-card bg-white rounded-2xl border border-surface-200 overflow-hidden group"
  data-category={category}
  data-subcategory={subcategory}
  style={`animation-delay: ${index * 0.06}s`}
>
  <a href={`/catalog/${slug}`} class="block">
    <!-- Image Container -->
    <div class="relative aspect-[3/4] overflow-hidden bg-surface-100">
      <img
        src={image}
        alt={name}
        class="product-image w-full h-full object-cover"
        loading="lazy"
        decoding="async"
      />
      {imageHover && (
        <img
          src={imageHover}
          alt={`${name} — альтернативный вид`}
          class="product-image absolute inset-0 w-full h-full object-cover opacity-0 group-hover:opacity-100 transition-opacity duration-500"
          loading="lazy"
          decoding="async"
        />
      )}

      <!-- Category Badge -->
      <div class="absolute top-3 left-3">
        <span class="inline-flex items-center px-2.5 py-1 bg-primary-700/90 backdrop-blur-sm text-white text-[11px] font-semibold rounded-lg">
          {category}
        </span>
      </div>

      <!-- Out of Stock Badge -->
      {!inStock && (
        <div class="absolute top-3 right-3">
          <span class="inline-flex items-center px-2.5 py-1 bg-surface-800/80 backdrop-blur-sm text-white text-[11px] font-semibold rounded-lg">
            Под заказ
          </span>
        </div>
      )}

      <!-- Quick Action Overlay -->
      <div class="absolute inset-x-0 bottom-0 p-3 translate-y-full group-hover:translate-y-0 transition-transform duration-300">
        <span class="flex items-center justify-center gap-2 w-full px-4 py-2.5 bg-white/95 backdrop-blur-sm text-primary-700 text-sm font-semibold rounded-xl shadow-lg">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" /></svg>
          Подробнее
        </span>
      </div>
    </div>

    <!-- Content -->
    <div class="p-4">
      <h3 class="text-[15px] font-semibold text-surface-800 mb-2 line-clamp-2 leading-snug group-hover:text-primary-700 transition-colors duration-200">
        {name}
      </h3>

      <!-- Category & Subcategory -->
      <div class="flex flex-wrap gap-1.5 mb-3">
        {subcategory && (
          <span class="inline-flex items-center px-2 py-0.5 bg-primary-50 text-primary-700 text-[11px] font-medium rounded-md">
            {subcategory}
          </span>
        )}
      </div>

      <!-- Bottom: Price + Cart -->
      <div class="flex items-center justify-between pt-3 border-t border-surface-100">
        <div>
          <span class="text-sm font-bold text-surface-800">{price}</span>
          <p class="text-[10px] text-surface-400 -mt-0.5">оптовая цена</p>
        </div>
        <button
          class="add-to-cart-btn inline-flex items-center gap-1.5 px-3.5 py-2 bg-primary-700 hover:bg-primary-800 text-white text-xs font-semibold rounded-lg transition-all duration-200 shadow-sm hover:shadow-md"
          data-product-id={id}
          data-product-name={name}
          aria-label={`Добавить ${name} в корзину`}
        >
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6" /></svg>
          В корзину
        </button>
      </div>
    </div>
  </a>
</article>
