---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroSection from '../components/HeroSection.astro';
import CategorySidebar from '../components/CategorySidebar.astro';
import FilterSidebar from '../components/FilterSidebar.astro';
import ProductCard from '../components/ProductCard.astro';
import Pagination from '../components/Pagination.astro';
import AboutSection from '../components/AboutSection.astro';
import DeliverySection from '../components/DeliverySection.astro';
import ContactsSection from '../components/ContactsSection.astro';

import { getCollection } from 'astro:content';
import categoriesData from '../data/categories.json';

const allProducts = await getCollection('products');

// Build category and subcategory counts
const categoryCounts: Record<string, number> = {};
const subcategoryCounts: Record<string, number> = {};

allProducts.forEach((p) => {
  const cat = p.data.category;
  const sub = p.data.subcategory;
  categoryCounts[cat] = (categoryCounts[cat] || 0) + 1;
  if (sub) {
    subcategoryCounts[sub] = (subcategoryCounts[sub] || 0) + 1;
  }
});

// Build filters based on new data structure (category filter handled by CategorySidebar, keep subcategory and inStock)
const subcategories = [...new Set(allProducts.map((p) => p.data.subcategory).filter(Boolean))];
const stockOptions = [
  { label: 'В наличии', value: 'true' },
  { label: 'Под заказ', value: 'false' },
];

const filters = [
  {
    id: 'subcategory',
    label: 'Подкатегория',
    options: subcategories.map((s) => ({ label: s, value: s })),
  },
  {
    id: 'inStock',
    label: 'Наличие',
    options: stockOptions,
  },
];

const activeFilters: Record<string, string[]> = {};
const PRODUCTS_PER_PAGE = 12;
---

<BaseLayout
  title="КаскадТекс — Ткани оптом в Беларуси"
  description="Оптовая продажа тканей ПВХ и ПУ, оксфорд, таффета, фурнитура и сопутствующие материалы. Широкий ассортимент, конкурентные цены, доставка по Беларуси."
>
  <HeroSection />

  <!-- Catalog Section -->
  <section id="catalog" class="py-10 lg:py-14 bg-surface-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-end justify-between mb-6">
        <div>
          <h2 class="text-2xl lg:text-3xl font-bold text-surface-900">Каталог</h2>
          <p class="text-surface-400 text-sm mt-1">Выберите категорию или параметры для фильтрации</p>
        </div>
        <div id="product-count" class="text-sm text-surface-500 bg-white px-3 py-1.5 rounded-lg border border-surface-200">
          Товаров: <span id="count-value" class="font-bold text-primary-700">{allProducts.length}</span>
        </div>
      </div>

      <div class="flex flex-col lg:flex-row gap-6">
        <!-- Left Sidebar: Categories + Filters -->
        <div class="w-full lg:w-72 shrink-0 space-y-4">
          <CategorySidebar categoryCounts={categoryCounts} subcategoryCounts={subcategoryCounts} />
          <FilterSidebar filters={filters} activeFilters={activeFilters} />
        </div>

        <!-- Product Grid -->
        <div class="flex-1">
          <!-- Active Category Breadcrumb -->
          <div id="active-category-breadcrumb" class="hidden mb-4">
            <div class="inline-flex items-center gap-2 px-3 py-2 bg-primary-50 border border-primary-200 rounded-xl text-sm">
              <svg class="w-4 h-4 text-primary-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z" /></svg>
              <span id="breadcrumb-text" class="text-primary-700 font-medium"></span>
              <button id="breadcrumb-clear" class="ml-1 text-primary-400 hover:text-primary-700 transition-colors" aria-label="Сбросить категорию">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
              </button>
            </div>
          </div>

          <div
            id="product-grid"
            class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-3 gap-5"
          >
            {allProducts.map((product, index) => (
              <div
                class="product-wrapper animate-fade-in-up opacity-0"
                data-category={product.data.category}
                data-subcategory={product.data.subcategory}
                data-instock={String(product.data.inStock)}
                style={`animation-delay: ${index * 0.06}s`}
              >
                <ProductCard
                  id={product.data.productId}
                  slug={product.data.slug}
                  name={product.data.name}
                  category={product.data.category}
                  subcategory={product.data.subcategory}
                  image={product.data.image}
                  imageHover={product.data.imageHover}
                  inStock={product.data.inStock}
                  price={product.data.price}
                  index={index}
                />
              </div>
            ))}
          </div>

          <div id="no-results" class="hidden text-center py-16">
            <div class="w-16 h-16 bg-surface-100 rounded-2xl flex items-center justify-center mx-auto mb-4">
              <svg class="w-8 h-8 text-surface-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
              </svg>
            </div>
            <h3 class="text-lg font-bold text-surface-700 mb-2">Ничего не найдено</h3>
            <p class="text-surface-500 text-sm">Попробуйте изменить параметры фильтрации</p>
          </div>

          <Pagination totalProducts={allProducts.length} perPage={PRODUCTS_PER_PAGE} />
        </div>
      </div>
    </div>
  </section>

  <AboutSection />
  <DeliverySection />
  <ContactsSection />
</BaseLayout>
