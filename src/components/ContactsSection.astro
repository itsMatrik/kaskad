---
const phone = '+375(29) 760-46-93';
const email = 'golodok_07@mail.ru';
---

<section id="contacts" class="py-16 lg:py-20 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12">
      <div class="inline-flex items-center gap-2 px-3 py-1.5 bg-primary-50 border border-primary-100 rounded-full text-primary-700 text-xs font-semibold tracking-wide uppercase mb-4">
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
        Контакты
      </div>
      <h2 class="text-2xl lg:text-3xl font-bold text-surface-900 mb-4">Свяжитесь с нами</h2>
      <p class="text-surface-500 max-w-2xl mx-auto">
        Готовы ответить на ваши вопросы, подобрать ткань под задачу или рассчитать стоимость заказа.
      </p>
    </div>

    <div class="grid lg:grid-cols-5 gap-8">
      <!-- Contact Info -->
      <div class="lg:col-span-2 space-y-4">
        <div class="flex items-start gap-4 p-5 bg-primary-50 rounded-2xl border border-primary-100">
          <div class="w-11 h-11 bg-primary-100 rounded-xl flex items-center justify-center shrink-0">
            <svg class="w-5 h-5 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
          </div>
          <div>
            <div class="text-sm font-bold text-surface-800">Телефон</div>
            <a href={`tel:${phone.replace(/[^+\d]/g, '')}`} class="text-primary-700 hover:text-primary-800 font-medium transition-colors">{phone}</a>
            <p class="text-xs text-surface-400 mt-1">Пн—Пт: 9:00—18:00</p>
          </div>
        </div>

        <div class="flex items-start gap-4 p-5 bg-accent-50 rounded-2xl border border-accent-100">
          <div class="w-11 h-11 bg-accent-100 rounded-xl flex items-center justify-center shrink-0">
            <svg class="w-5 h-5 text-accent-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
          </div>
          <div>
            <div class="text-sm font-bold text-surface-800">Email</div>
            <a href={`mailto:${email}`} class="text-accent-700 hover:text-accent-800 font-medium transition-colors">{email}</a>
            <p class="text-xs text-surface-400 mt-1">Ответим в течение 24 часов</p>
          </div>
        </div>

        <div class="flex items-start gap-4 p-5 bg-surface-50 rounded-2xl border border-surface-200">
          <div class="w-11 h-11 bg-surface-100 rounded-xl flex items-center justify-center shrink-0">
            <svg class="w-5 h-5 text-surface-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
          </div>
          <div>
            <div class="text-sm font-bold text-surface-800">Адрес склада</div>
            <p class="text-surface-600 text-sm font-medium">г. Минск, улица Васнецова, 48</p>
            <p class="text-xs text-surface-400 mt-1">Самовывоз по согласованию</p>
          </div>
        </div>
      </div>

      <!-- Contact Form -->
      <div class="lg:col-span-3">
        <form class="bg-surface-50 rounded-2xl p-6 lg:p-8 border border-surface-200" id="contact-form">
          <h3 class="font-bold text-surface-800 mb-1.5 text-lg">Запросить прайс-лист</h3>
          <p class="text-sm text-surface-500 mb-6">Или задать вопрос о наличии и стоимости тканей</p>
          <div class="grid sm:grid-cols-2 gap-4 mb-4">
            <div>
              <label for="contact-name" class="block text-sm font-semibold text-surface-700 mb-1.5">Имя <span class="text-red-400">*</span></label>
              <input
                type="text"
                id="contact-name"
                name="name"
                required
                class="w-full px-4 py-2.5 border border-surface-200 rounded-xl text-sm focus:border-primary-400 focus:ring-2 focus:ring-primary-100 transition-all duration-200 bg-white"
                placeholder="Ваше имя"
              />
            </div>
            <div>
              <label for="contact-company" class="block text-sm font-semibold text-surface-700 mb-1.5">Компания</label>
              <input
                type="text"
                id="contact-company"
                name="company"
                class="w-full px-4 py-2.5 border border-surface-200 rounded-xl text-sm focus:border-primary-400 focus:ring-2 focus:ring-primary-100 transition-all duration-200 bg-white"
                placeholder="Название компании"
              />
            </div>
          </div>
          <div class="grid sm:grid-cols-2 gap-4 mb-4">
            <div>
              <label for="contact-phone" class="block text-sm font-semibold text-surface-700 mb-1.5">Телефон <span class="text-red-400">*</span></label>
              <input
                type="tel"
                id="contact-phone"
                name="phone"
                required
                class="w-full px-4 py-2.5 border border-surface-200 rounded-xl text-sm focus:border-primary-400 focus:ring-2 focus:ring-primary-100 transition-all duration-200 bg-white"
                placeholder="+375 (__) ___-__-__"
              />
            </div>
            <div>
              <label for="contact-email" class="block text-sm font-semibold text-surface-700 mb-1.5">Email</label>
              <input
                type="email"
                id="contact-email"
                name="email"
                class="w-full px-4 py-2.5 border border-surface-200 rounded-xl text-sm focus:border-primary-400 focus:ring-2 focus:ring-primary-100 transition-all duration-200 bg-white"
                placeholder="email@example.com"
              />
            </div>
          </div>
          <div class="mb-5">
            <label for="contact-message" class="block text-sm font-semibold text-surface-700 mb-1.5">Сообщение</label>
            <textarea
              id="contact-message"
              name="message"
              rows="4"
              class="w-full px-4 py-2.5 border border-surface-200 rounded-xl text-sm focus:border-primary-400 focus:ring-2 focus:ring-primary-100 transition-all duration-200 bg-white resize-y"
              placeholder="Опишите ваш запрос: интересующие ткани, количество, сроки..."
            ></textarea>
          </div>
          <button
            type="submit"
            class="btn-primary w-full sm:w-auto px-8 py-3.5 bg-primary-700 hover:bg-primary-800 text-white font-bold rounded-xl text-sm"
          >
            Отправить запрос
          </button>
        </form>
      </div>
    </div>
  </div>
</section>
