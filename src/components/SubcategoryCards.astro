---
import categoriesData from '../data/categories.json';

interface SubcategoryInfo {
  name: string;
  image: string;
}

interface CategoryInfo {
  slug: string;
  image: string;
  children: SubcategoryInfo[];
}

const categories = categoriesData as Record<string, CategoryInfo>;

export interface Props {
  subcategoryData: Record<string, { name: string; image: string; count: number; parentCategory: string }[]>;
}

const { subcategoryData } = Astro.props;
---

<div id="subcategory-cards-container" class="hidden mb-8 pb-6 border-b-2 border-surface-300 sm:mb-6 sm:pb-0 sm:border-b-0">
  <div class="flex items-center justify-between mb-4">
    <h3 class="text-lg font-bold text-surface-800" id="subcategory-title">Подкатегории</h3>
    <button
      id="subcategory-clear"
      class="text-sm text-primary-600 hover:text-primary-800 font-semibold transition-colors duration-200"
    >
      Показать все товары
    </button>
  </div>
  <div id="subcategory-cards-grid" class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 xl:grid-cols-5 gap-4">
    {Object.entries(subcategoryData).map(([catName, subcats]) => (
      subcats.map((sub) => (
        <button
          class="subcategory-card group relative bg-white rounded-2xl border border-surface-200 overflow-hidden hover:border-primary-400 hover:shadow-lg transition-all duration-300"
          data-parent-category={catName}
          data-subcategory={sub.name}
        >
          <div class="aspect-[4/3] overflow-hidden bg-surface-100">
            <img
              src={sub.image}
              alt={sub.name}
              class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500"
              loading="lazy"
              decoding="async"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-black/10 to-transparent"></div>
          </div>
          <div class="absolute bottom-0 inset-x-0 p-3">
            <h4 class="text-white font-bold text-sm leading-tight drop-shadow-md">{sub.name}</h4>
            <span class="text-white/80 text-xs mt-0.5 block">{sub.count} товаров</span>
          </div>
        </button>
      ))
    ))}
  </div>
</div>
